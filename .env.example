# ─────────────────────────────────────────────────────────────
# Veritas Backend — environment variables
# Copy this file to .env and fill in the values,
# or use the setup wizard: http://localhost:3000/setup
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection — leave empty on first install (configured in step 2 of /setup)
# DATABASE_URL=postgres://veritas_user:password@localhost:5432/veritas_db
DATABASE_URL=

# Application secrets (generate random values in production)
JWT_SECRET=
ENCRYPTION_KEY=

# Server
PORT=3001
NODE_ENV=development
PROTOCOL=http

# CORS — allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# Frontend URL (password reset links)
FRONTEND_BASE_URL=http://localhost:3000

# Edition: community (OSS, default) or pro (commercial license)
# For local Pro without a key: VERITAS_EDITION=pro + NODE_ENV=development
VERITAS_EDITION=community

# Pro license (production) — key received after subscribing at veritas-msp.com
# VERITAS_LICENSE_KEY=VRT-PRO-XXXX-XXXX-XXXX-XXXX

# Pro license validation: billing URL and secret are embedded in code (constants/billing.js).
# Only VERITAS_LICENSE_KEY (above) needs to be set to enable Pro in production.

# License validation cache (ms) — default 5000. Set 0 to re-check on every API request.
# LICENSE_CACHE_MS=5000

# Integration fallbacks (optional — most are stored encrypted in the database)
# SMTP_USER=
# SMTP_PASS=
